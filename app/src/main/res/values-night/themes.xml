<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!--  Primary  -->
        <item name="colorPrimary">@color/blue_primary_dark</item>
        <item name="colorOnPrimary">@color/blue_on_primary_dark</item>
        <item name="colorPrimaryContainer">@color/blue_primary_container_dark</item>
        <item name="colorOnPrimaryContainer">@color/blue_on_primary_container_dark</item>
        <!--  Secondary  -->
        <item name="colorSecondary">@color/blue_secondary_dark</item>
        <item name="colorOnSecondary">@color/blue_on_secondary_dark</item>
        <item name="colorSecondaryContainer">@color/blue_secondary_container_dark</item>
        <item name="colorOnSecondaryContainer">@color/blue_on_secondary_container_dark</item>
        <!--  Tertiary  -->
        <item name="colorTertiary">@color/blue_tertiary_dark</item>
        <item name="colorOnTertiary">@color/blue_on_tertiary_dark</item>
        <item name="colorTertiaryContainer">@color/blue_tertiary_container_dark</item>
        <item name="colorOnTertiaryContainer">@color/blue_on_tertiary_container_dark</item>
        <!--  Background and Surface  -->
        <item name="android:colorBackground">@color/blue_background_dark</item>
        <item name="colorSurface">@color/blue_surface_dark</item>
        <item name="colorOnSurface">@color/blue_on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/blue_surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/blue_on_surface_variant_dark</item>
        <!--  Outline  -->
        <item name="colorOutline">@color/blue_outline_dark</item>
        <item name="colorOutlineVariant">@color/blue_outline_variant_dark</item>
        <!--  Status Bar  -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication"/>
</resources>