<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Branding Colors -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/blue_on_primary</item>
        <item name="colorPrimaryContainer">@color/blue_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/blue_on_primary_container</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/blue_secondary</item>
        <item name="colorOnSecondary">@color/blue_on_secondary</item>
        <item name="colorSecondaryContainer">@color/blue_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/blue_on_secondary_container</item>

        <!-- Tertiary / Accent Colors -->
        <item name="colorTertiary">@color/blue_tertiary</item>
        <item name="colorOnTertiary">@color/blue_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/blue_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/blue_on_tertiary_container</item>

        <!-- Background and Surface -->
        <item name="android:colorBackground">@color/blue_surface</item>
        <item name="colorSurface">@color/blue_surface</item>
        <item name="colorOnSurface">@color/blue_on_surface</item>
        <item name="colorSurfaceVariant">@color/blue_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/blue_on_surface_variant</item>

        <!-- Outline -->
        <item name="colorOutline">@color/blue_outline</item>
        <item name="colorOutlineVariant">@color/blue_outline_variant</item>

        <!-- Status Bar Configuration -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Dark theme overrides -->
    <style name="Base.Theme.MyApplication.Dark" parent="Base.Theme.MyApplication">
        <item name="colorPrimary">@color/blue_primary_dark</item>
        <item name="colorOnPrimary">@color/blue_on_primary_dark</item>
        <item name="colorPrimaryContainer">@color/blue_primary_container_dark</item>
        <item name="colorOnPrimaryContainer">@color/blue_on_primary_container_dark</item>

        <item name="colorSecondary">@color/blue_secondary_dark</item>
        <item name="colorOnSecondary">@color/blue_on_secondary_dark</item>
        <item name="colorSecondaryContainer">@color/blue_secondary_container_dark</item>
        <item name="colorOnSecondaryContainer">@color/blue_on_secondary_container_dark</item>

        <item name="colorTertiary">@color/blue_tertiary_dark</item>
        <item name="colorOnTertiary">@color/blue_on_tertiary_dark</item>
        <item name="colorTertiaryContainer">@color/blue_tertiary_container_dark</item>
        <item name="colorOnTertiaryContainer">@color/blue_on_tertiary_container_dark</item>

        <item name="android:colorBackground">@color/blue_background_dark</item>
        <item name="colorSurface">@color/blue_surface_dark</item>
        <item name="colorOnSurface">@color/blue_on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/blue_surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/blue_on_surface_variant_dark</item>

        <item name="colorOutline">@color/blue_outline_dark</item>
        <item name="colorOutlineVariant">@color/blue_outline_variant_dark</item>

        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.MyApplication" parent="Base.Theme.MyApplication" />
</resources>
